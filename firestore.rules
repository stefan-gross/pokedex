rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Nutzer-Sammlung — nur eingeloggte User
    match /cards/{id} {
      allow read, write: if request.auth != null;
    }
    match /cards/{cardId}/priceHistory/{id} {
      allow read, write: if request.auth != null;
    }
    match /binders/{id} {
      allow read, write: if request.auth != null;
    }
    match /wishlists/{id} {
      allow read, write: if request.auth != null;
    }

    // Pokémon-Kartenkatalog — öffentliche Daten, kein Auth nötig
    // Schreibzugriff nur vom Server (geschützt durch API-Route + Session)
    match /tcg_catalog/{id} {
      allow read, write: if true;
    }
    match /tcg_catalog_meta/{id} {
      allow read, write: if true;
    }
  }
}
